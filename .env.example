# LLM para diagnóstico y zonas dinámicas — con una alcanza:
# GEMINI_API_KEY: gratis, sin tarjeta → https://aistudio.google.com/apikey
# ANTHROPIC_API_KEY: opcional, de pago — solo se usa si no hay key de Gemini
# GEMINI_MODEL: por defecto gemini-3.1-pro-preview (mejor razonamiento Google)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
ANTHROPIC_API_KEY=
# CoinMarketCap (gratis, plan Basic) para Fear&Greed y dominancia
CMC_API_KEY=
